{% extends "base.htm.j2" %}

{% block title %}Say Thank You{% endblock %}

{% block extra_head %}

    <style>
        pre {
            max-width: 600px!important;
        }
        .archived-notes-grid {
            width: 100%;
            margin-bottom: 1.5rem;
        }
        .archived-notes-header {
            display: grid;
            grid-template-columns: 1fr auto auto;
            gap: 1rem;
            padding: 0.5rem;
            background-color: #f5f5f5;
            font-weight: bold;
        }
        .archived-notes-list {
            display: flex;
            flex-direction: column;
        }
        .archived-note-item {
            display: grid;
            grid-template-columns: 1fr auto auto;
            gap: 1rem;
            padding: 0.5rem;
            border-bottom: 1px solid #eee;
        }
    </style>
{% endblock %}

{% block content %}


<form action="{{ url_for('user_logout') }}" method="POST">
<button type="submit" class="logoutLblPos" >Log Out</button>
</form>

<img class="avatar" style="border-radius: 50%;" src="{{user['picture']}}"/ width=100px;>

<p><a href="{{ url_for('inbox')}}">Go to regular inbox</a>.</p>

<hr>

<p style="text-align: center;">
  <h3>Archived Notes:</h3>
</p>


<section class="archived-notes-grid">
  <header class="archived-notes-header">
    <div class="header-cell">Message</div>
    <div class="header-cell">From</div>
    <div class="header-cell">Share URL</div>
  </header>
  <div class="archived-notes-list">
  {% for note in notes %}
    <article class="archived-note-item">
      <div class="note-cell"><pre class='note'>{{ note.body }}</pre></div>
      <div class="note-cell"><pre class='note'><strong>— {{ note.byline }}</strong></pre></div>
      <div class="note-cell"><strong><a class="share" href="{{ url_for('share_note', uuid=note.uuid)}}">🔗</a></strong></div>
    </article>
  {% endfor %}
  </div>
</section>

<p><a href="{{ url_for('inbox')}}">Go to regular inbox</a>.</p>


<p><strong>Note:</strong> this website is a work in progress, and these settings will be moved to a separate settings page in the near future. If you'd like to help, send a pull request! :)</p>


{% endblock %}
